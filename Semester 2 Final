package finalcsproject;

import java.util.*;
import java.io.*;

public class FinalCSProject {

    public final static String SAVE_PATH = "save.txt";
    public final static String ITEM_PATH = "item.txt";
    public final static String ROOM_PATH = "room.txt";
    public final static String PUZZLE_PATH = "puzzle.txt";
    private static ArrayList<Item> gameItems = new ArrayList<>();
    private static ArrayList<Room> gameRooms = new ArrayList<>();
    private static ArrayList<Puzzle> gamePuzzles = new ArrayList<>();
    private static Room currentRoom;
    private static Room finalRoom;
    
    public static void main(String[] args) {
        
        
        
    }
    
    private static ArrayList<Item> getInventory(){
        ArrayList<Item> inventoryItems = new ArrayList();
        for(Item i : gameItems){
            if(i.getLocation().equals("player")){
                inventoryItems.add(i);
            }
        }
        return inventoryItems;
    }
    
    private static ArrayList<String> getFile(String path) {
        try (BufferedReader reader = new BufferedReader(new FileReader(path))) {
            return new ArrayList<>(reader.readAllLines());
        } catch (IOException e) {
            System.err.println("Error reading file: " + path);
            return new ArrayList<>();
        }
    }
    
    private static ArrayList<Item> getItems() {

        ArrayList<Item> items = new ArrayList<>();
        ArrayList<String> rawLines = getFile(ITEM_PATH);

        boolean inObject = false;
        String currentTag = null;

        String name = "";
        String location = "";
        String countStr = "";
        String description = "";

        for (String line : rawLines) {

            
            if (inObject) {

                if (line.equals("<name>")) currentTag = "name";
                else if (line.equals("</name>")) currentTag = null;

                else if (line.equals("<location>")) currentTag = "location";
                else if (line.equals("</location>")) currentTag = null;

                else if (line.equals("<count>")) currentTag = "count";
                else if (line.equals("</count>")) currentTag = null;

                else if (line.equals("<description>")) currentTag = "description";
                else if (line.equals("</description>")) currentTag = null;

                else if ("name".equals(currentTag)) name += line + "\n";
                else if ("location".equals(currentTag)) location += line + "\n";
                else if ("count".equals(currentTag)) countStr += line;
                else if ("description".equals(currentTag)) description += line + "\n";
            }else if (line.equals("OBJECT")) {
                inObject = true;
                name = location = countStr = description = "";
                currentTag = null;
            }
            else if (line.equals("END_OBJECT")) {
                items.add(new Item(name.trim(),Integer.parseInt(countStr.trim()),location.trim(),description.trim()));
                inObject = false;
            }
        }
        return items;
    }
    
    private static ArrayList<Room> getRooms(ArrayList<Puzzle> puzzles) {

        ArrayList<Room> rooms = new ArrayList<>();
        ArrayList<String> rawLines = getFile(ROOM_PATH);
        
        boolean inObject = false;
        String currentTag = null;
        
        String name = "";
        String description = "";
        String connectionsStr = "";
        String itemsStr = "";
        String puzzle = "";
        
        for (String line : rawLines) {
            
            
            if (inObject) {

                if (line.equals("<name>")) currentTag = "name";
                else if (line.equals("</name>")) currentTag = null;

                else if (line.equals("<description>")) currentTag = "description";
                else if (line.equals("</description>")) currentTag = null;

                else if (line.equals("<connections>")) currentTag = "connections";
                else if (line.equals("</connections>")) currentTag = null;

                else if (line.equals("<items>")) currentTag = "items";
                else if (line.equals("</items>")) currentTag = null;

                else if (line.equals("<puzzle>")) currentTag = "puzzle";
                else if (line.equals("</puzzle>")) currentTag = null;
                
                else if ("name".equals(currentTag)) name += line + "\n";
                else if ("description".equals(currentTag)) description += line + "\n";
                else if ("connections".equals(currentTag)) connectionsStr += line;
                else if ("items".equals(currentTag)) itemsStr += line;
                else if ("puzzle".equals(currentTag)) puzzle += line;
            }else if (line.equals("OBJECT")) {
                inObject = true;
                name = description = connectionsStr = itemsStr = puzzle = "";
                currentTag = null;
            }else if (line.equals("END_OBJECT")) {
                
                ArrayList<String> connections = new ArrayList<>();
                ArrayList<String> items = new ArrayList<>();
                
                if (!connectionsStr.trim().isEmpty()) {
                    for (String c : connectionsStr.split(",")) {
                        connections.add(c.trim());
                    }
                }
                
                if (!itemsStr.trim().isEmpty()) {
                    for (String i : itemsStr.split(",")) {
                        items.add(i.trim());
                    }
                }
                
                Puzzle matchedPuzzle = null;
                for (Puzzle p : puzzles) {
                    if (p.getPrompt().equals(puzzle.trim())) {
                        matchedPuzzle = p;
                    }
                }
                
                rooms.add(new Room(name.trim(),description.trim(),connections,items,matchedPuzzle));

            inObject = false;
            }
        }
        
        return rooms;
    }
    
    private static ArrayList<Puzzle> getPuzzles() {
        
        ArrayList<Puzzle> puzzles = new ArrayList<>();
        ArrayList<String> rawLines = getFile(PUZZLE_PATH);
        
        boolean inObject = false;
        String currentTag = null;
        
        String prompt = "";
        String answer = "";
        
        for (String line : rawLines) {
            
            
            if (inObject) {
                
                if (line.equals("<prompt>")) currentTag = "prompt";
                else if (line.equals("</prompt>")) currentTag = null;
                
                else if (line.equals("<answer>")) currentTag = "answer";
                else if (line.equals("</answer>")) currentTag = null;
                
                else if ("prompt".equals(currentTag)) prompt += line + "\n";
                else if ("answer".equals(currentTag)) answer += line + "\n";
                
            }else if (line.equals("OBJECT")) {
                inObject = true;
                prompt = answer = "";
                currentTag = null;
            }else if (line.equals("END_OBJECT")) {
                puzzles.add(new Puzzle(
                    prompt.trim(),
                    answer.trim()
                ));
                inObject = false;
            }
        }
        
        return puzzles;
        
    }
    
}

class Item {

    private final String name;
    private int count;
    private String location;
    private final String description;

    public Item(String name, int count, String location, String description) {
        this.name = name;
        this.count = count;
        this.location = location;
        this.description = description;
    }

    public String getName() { return name; }
    public int getCount() { return count; }
    public String getLocation() { return location; }
    public String getDescription() { return description; }

    public void setCount(int count) { this.count = count; }
    public void setLocation(String location) { this.location = location; }
    
    @Override
    public String toString() {
        return "Item{name='" + name + "', count=" + count + ", location='" + location + "'}";
    }
    
}

class Room {

    private final String name;
    private String description;
    private ArrayList<String> connections;
    private ArrayList<String> items;
    private Puzzle puzzle;

    public Room(String name, String description,
                ArrayList<String> connections,
                ArrayList<String> items,
                Puzzle puzzle) {
        this.name = name;
        this.description = description;
        this.connections = connections;
        this.items = items;
        this.puzzle = puzzle;
    }

    public String getName() { return name; }
    public String getDescription() { return description; }
    public ArrayList<String> getConnections() { return connections; }
    public ArrayList<String> getItems() { return items; }

    public void setDescription(String description) { this.description = description; }

    public void addConnection(String room) { if (!connections.contains(room)) connections.add(room); }
    public void removeConnection(String room) { connections.remove(room); }

    public void addItem(String item) { items.add(item); }
    public void removeItem(String item) { items.remove(item); }

    public String getPuzzlePrompt() { return puzzle != null ? puzzle.getPrompt() : null; }
    public boolean isPuzzleSolved() { return puzzle != null && puzzle.isSolved(); }
    public void tryPuzzleAnswer(String input) { if (puzzle != null) puzzle.tryAnswer(input); }

    public boolean hasPuzzle() { return puzzle != null; }
    
    @Override
    public String toString() {
        return "Room{name='" + name + "', connections=" + connections + ", items=" + items + "}";
    }
    
}

class Puzzle {

    private final String prompt;
    private final String answer;
    private boolean solved;

    public Puzzle(String prompt, String answer) {
        this.prompt = prompt;
        this.answer = answer;
        this.solved = false;
    }

    public String getPrompt() { return prompt; }

    public boolean isSolved() { return solved; }

    public void tryAnswer(String input) {
        if (!solved && answer.equalsIgnoreCase(input)) {
            solved = true;
        }
    }
    
    @Override
    public String toString() {
        return "Puzzle{prompt='" + prompt + "', solved=" + solved + "}";
    }
    
}
