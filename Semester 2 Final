class Item {

    private final String name;
    private int count;
    private String location;
    private final String description;

    public Item(String name, int count, String location, String description) {
        this.name = name;
        this.count = count;
        this.location = location;
        this.description = description;
    }

    public String getName() { return name; }
    public int getCount() { return count; }
    public String getLocation() { return location; }
    public String getDescription() { return description; }

    public void setCount(int count) { this.count = count; }
    public void setLocation(String location) { this.location = location; }
    
    @Override
    public String toString() {
        return "Item{name='" + name + "', count=" + count + ", location='" + location + "'}";
    }
    
    public String saveString(){
        
        String run = "";
        
        run = run + "OBJECT\n";
        run = run + "<name>\n";
        run = run + name+"\n";
        run = run + "</name>\n";
        run = run + "<count>\n";
        run = run + count+"\n";
        run = run + "</count>\n";
        run = run + "<location>\n";
        run = run + location+"\n";
        run = run + "</location>\n";
        run = run + "<description>\n";
        run = run + description+"\n";
        run = run + "</description>\n";
        run = run + "END_OBJECT\n";
        
        return run;
        
    }

    
}

class Room {

    private final String name;
    private String description;
    private ArrayList<String> connections;
    private ArrayList<String> items;
    private Puzzle puzzle;
    private String itemRequired = null;
    private int itemConsumed = 0;
    private boolean roomOpen;

    public Room(String name, String description, ArrayList<String> connections, ArrayList<String> items, Puzzle puzzle, String itemRequired, int itemConsumed, boolean roomOpen) {
        this.name = name;
        this.description = description;
        this.connections = connections;
        this.items = items;
        this.puzzle = puzzle;
        this.itemRequired = itemRequired;
        this.itemConsumed = itemConsumed;
        this.roomOpen = roomOpen;
        
    }

    public String getName() { return name; }
    public String getDescription() { return description; }
    public ArrayList<String> getConnections() { return connections; }
    public ArrayList<String> getItems() { return items; }

    public void setDescription(String description) { this.description = description; }

    public void addConnection(String room) { if (!connections.contains(room)) connections.add(room); }
    public void removeConnection(String room) { connections.remove(room); }

    public void addItem(String item) { items.add(item); }
    public void removeItem(String item) { items.remove(item); }

    public String getPuzzlePrompt() { return puzzle != null ? puzzle.getPrompt() : null; }
    public boolean isPuzzleSolved() { return puzzle != null && puzzle.isSolved(); }
    public void tryPuzzleAnswer(String input) { if (puzzle != null) puzzle.tryAnswer(input); }
    
    public boolean tryEnter(){
        if(itemRequired == null){return true;}
        if(roomOpen){return true;}
        int count = 0;
        for(Item i : FinalCSProject.getInventory()){
            if(i.getName().equals(itemRequired)){
                count+=i.getCount();
            }
        }
        if(count>0&&count>=itemConsumed){
            FinalCSProject.useItem(count, itemRequired);
            roomOpen = true;
            return true;
        }else{return false;}
    }
    
    public boolean hasPuzzle() { return puzzle != null; }
    
    @Override
    public String toString() {
        return "Room{name='" + name + "', connections=" + connections + ", items=" + items + "}";
    }
    
    public String saveString(){
        
        String run = "";
        
        run = run + "OBJECT\n";
        run = run + "<description>\n";
        run = run + description+"\n";
        run = run + "</description>\n";
        run = run + "<name>\n";
        run = run + name+"\n";
        run = run + "</name>\n";
        run = run + "<connections>\n";
        for(String s : connections){run = run + s+",";}
        run = run + "\n</connections>\n";
        run = run + "<items>\n";
        for(String s : items){run = run + s+",";}
        run = run + "\n</items>\n";
        run = run + "END_OBJECT\n";
        
        return run;
        
    }
    
}

class Puzzle {

    private final String prompt;
    private final String answer;
    private boolean solved;

    public Puzzle(String prompt, String answer, boolean solved) {
        this.prompt = prompt;
        this.answer = answer;
        this.solved = solved;
    }

    public String getPrompt() { return prompt; }

    public boolean isSolved() { return solved; }

    public void tryAnswer(String input) {
        if (!solved && answer.equalsIgnoreCase(input)) {
            solved = true;
        }
    }
    
    @Override
    public String toString() {
        return "Puzzle{prompt='" + prompt + "', solved=" + solved + "}";
    }
    
    public String saveString(){
        
        String run = "";
        
        run = run + "OBJECT\n";
        run = run + "<prompt>\n";
        run = run + prompt+"\n";
        run = run + "</prompt>\n";
        run = run + "<answer>\n";
        run = run + answer+"\n";
        run = run + "</answer>\n";
        run = run + "<complete>\n";
        if(solved){run = run + "true\n";}else{run = run + "false\n";}
        run = run + "</complete>\n";
        run = run + "END_OBJECT\n";
        
        return run;
        
    }
    
}
