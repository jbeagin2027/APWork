class Thing{
    private String type = "";
    public void setType(String in){type=in;}
    public String getType(){return type;}
}

class ItemType extends Thing{
    
    private String ItemTypeName;
    private String ItemGroupName;
    private String ItemTypeSpec;

    public String getItemTypeName() {
        return ItemTypeName;
    }

    public String getItemGroupName() {
        return ItemGroupName;
    }

    public String getItemTypeSpec() {
        return ItemTypeSpec;
    }

    public ItemType(String ItemTypeName, String ItemGroupName, String ItemTypeSpec) {
        this.ItemTypeName = ItemTypeName;
        this.ItemGroupName = ItemGroupName;
        this.ItemTypeSpec = ItemTypeSpec;
    }
    
    
    
    public ItemType(){}
    
    class Item{
        
        private String location;
        private int count;
        private int itemVar1;
        private int itemVar2;

        public String getLocation() {
            return location;
        }

        public int getCount() {
            return count;
        }

        public int getItemVar1() {
            return itemVar1;
        }

        public int getItemVar2() {
            return itemVar2;
        }

        public Item(String location, int count, int itemVar1, int itemVar2) {
            this.location = location;
            this.count = count;
            this.itemVar1 = itemVar1;
            this.itemVar2 = itemVar2;
        }
        
        
        
    }
    
}

class Room extends Thing{
    
    private ArrayList<String> adjacentRooms;
    private ArrayList<ItemType.Item> items;
    private String puzzleInRoom;
    private boolean isFinalRoom;
    private boolean completed;
    private String roomName;
    private String itemRequired;
    private String roomContent;
    
    public Room(ArrayList<String> paths, ArrayList<ItemType.Item> it, String roompz, boolean fin, boolean comp, String name, String itemreq, String roomco){
        
        adjacentRooms = paths;
        items = it;
        puzzleInRoom = roompz;
        isFinalRoom = fin;
        completed = comp;
        roomName = name;
        itemRequired = itemreq;
        roomContent = roomco;
        
    }

    public ArrayList<String> getAdjacentRooms() {
        return adjacentRooms;
    }

    public ArrayList<ItemType.Item> getItems() {
        return items;
    }

    public String getPuzzleInRoom() {
        return puzzleInRoom;
    }

    public boolean isIsFinalRoom() {
        return isFinalRoom;
    }

    public boolean isCompleted() {
        return completed;
    }

    public String getRoomName() {
        return roomName;
    }

    public String getItemRequired() {
        return itemRequired;
    }

    public String getRoomContent() {
        return roomContent;
    }
    
    
    
}

class Puzzle extends Thing{
    
    private String puzzleScreen;
    private String winCondition;
    private String nextPuzzle;
    private String puzzleName;
    
    public String showPuzzle(){return puzzleScreen;}
    public String getNextPuzzle(){return nextPuzzle;}
    public String name(){return puzzleName;}
    public boolean isWinCondition(String input){return (winCondition.equalsIgnoreCase(input.trim()));}
    
    public Puzzle(String pzScreen, String pzWin, String pzNext, String pzName){
        
        puzzleScreen = pzScreen;
        winCondition = pzWin;
        nextPuzzle = pzNext;
        puzzleName = pzName;
        
    }
    
}
