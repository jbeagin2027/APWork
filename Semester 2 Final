    public static void useItem(int amount, String name){
        
        int left = amount;
        for(Item i : getInventory()){
            if(i.getName().equals(name)){
                if(i.getCount()<=left){
                    left-=i.getCount();
                    gameItems.remove(i);
                }else{
                    left = 0;
                    i.setCount(i.getCount()-left);
                }
            }
        }
    }
    
    private static void closeGame(){
        
        saveItems();
        saveRooms();
        savePuzzles();
        saveGame();
        exit = true;
        
    }
    
