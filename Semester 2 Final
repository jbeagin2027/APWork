    private static ArrayList<String> getFile(String path) {
        try (BufferedReader reader = new BufferedReader(new FileReader(path))) {
            ArrayList<String> lines = new ArrayList();
            boolean left = true;
            while(left){
                lines.add(reader.readLine());
                left = reader.ready();
            }
            return lines;
        } catch (IOException e) {
            System.err.println("Error reading file: " + path);
            return new ArrayList<>();
        }
    }
    
    private static ArrayList<Item> getItems() {

        ArrayList<Item> items = new ArrayList<>();
        ArrayList<String> rawLines = getFile(ITEM_PATH);

        boolean inObject = false;
        String currentTag = null;

        String name = "";
        String location = "";
        String countStr = "";
        String description = "";

        for (String line : rawLines) {

            if (line.equals("END_OBJECT")) {
                items.add(new Item(name.trim(),Integer.parseInt(countStr.trim()),location.trim(),description.trim()));
                inObject = false;
            }else if (inObject) {

                if (line.equals("<name>")) currentTag = "name";
                else if (line.equals("</name>")) currentTag = null;

                else if (line.equals("<location>")) currentTag = "location";
                else if (line.equals("</location>")) currentTag = null;

                else if (line.equals("<count>")) currentTag = "count";
                else if (line.equals("</count>")) currentTag = null;

                else if (line.equals("<description>")) currentTag = "description";
                else if (line.equals("</description>")) currentTag = null;

                else if ("name".equals(currentTag)) name += line + "\n";
                else if ("location".equals(currentTag)) location += line + "\n";
                else if ("count".equals(currentTag)) countStr += line;
                else if ("description".equals(currentTag)) description += line + "\n";
            }else if (line.equals("OBJECT")) {
                inObject = true;
                name = location = countStr = description = "";
                currentTag = null;
            }
        }
        return items;
    }
    
    private static ArrayList<Room> getRooms(ArrayList<Puzzle> puzzles) {

        ArrayList<Room> rooms = new ArrayList<>();
        ArrayList<String> rawLines = getFile(ROOM_PATH);
        
        boolean inObject = false;
        String currentTag = null;
        
        String name = "";
        String description = "";
        String connectionsStr = "";
        String itemsStr = "";
        String puzzle = "";
        String itemReq = "";
        String itemCon = "";
        String isOpen = "";
        boolean open = false;
        
        for (String line : rawLines) {
            
            if (line.equals("END_OBJECT")) {
                
                ArrayList<String> connections = new ArrayList<>();
                ArrayList<String> items = new ArrayList<>();
                
                if (!connectionsStr.trim().isEmpty()) {
                    for (String c : connectionsStr.split(",")) {
                        connections.add(c.trim());
                    }
                }
                
                if (!itemsStr.trim().isEmpty()) {
                    for (String i : itemsStr.split(",")) {
                        items.add(i.trim());
                    }
                }
                
                Puzzle matchedPuzzle = null;
                for (Puzzle p : puzzles) {
                    if (p.getPrompt().equals(puzzle.trim())) {
                        matchedPuzzle = p;
                    }
                }
                
                if(isOpen.equals("true")){open = true;}
                
                rooms.add(new Room(name.trim(),description.trim(),connections,items,matchedPuzzle,itemReq,Integer.parseInt(itemCon),open));

            inObject = false;
            }else if (inObject) {

                if (line.equals("<name>")) currentTag = "name";
                else if (line.equals("</name>")) currentTag = null;

                else if (line.equals("<description>")) currentTag = "description";
                else if (line.equals("</description>")) currentTag = null;

                else if (line.equals("<connections>")) currentTag = "connections";
                else if (line.equals("</connections>")) currentTag = null;

                else if (line.equals("<items>")) currentTag = "items";
                else if (line.equals("</items>")) currentTag = null;

                else if (line.equals("<puzzle>")) currentTag = "puzzle";
                else if (line.equals("</puzzle>")) currentTag = null;
                
                else if (line.equals("<itemreq>")) currentTag = "itemreq";
                else if (line.equals("</itemreq>")) currentTag = null;
                
                else if (line.equals("<itemcon>")) currentTag = "itemcon";
                else if (line.equals("</itemcon>")) currentTag = null;
                
                else if (line.equals("<open>")) currentTag = "open";
                else if (line.equals("</open>")) currentTag = null;
                
                else if ("name".equals(currentTag)) name += line + "\n";
                else if ("description".equals(currentTag)) description += line + "\n";
                else if ("connections".equals(currentTag)) connectionsStr += line;
                else if ("items".equals(currentTag)) itemsStr += line;
                else if ("puzzle".equals(currentTag)) puzzle += line;
                else if ("itemreq".equals(currentTag)) itemReq += line;
                else if ("itemcon".equals(currentTag)) itemCon += line;
                else if ("open".equals(currentTag)) isOpen += line;
                
            }else if (line.equals("OBJECT")) {
                inObject = true;
                name = description = connectionsStr = itemsStr = puzzle = "";
                currentTag = null;
            }
        }
        
        return rooms;
    }
    
    private static ArrayList<Puzzle> getPuzzles() {
        
        ArrayList<Puzzle> puzzles = new ArrayList<>();
        ArrayList<String> rawLines = getFile(PUZZLE_PATH);
        
        boolean inObject = false;
        String currentTag = null;
        
        String prompt = "";
        String answer = "";
        String complete = "";
        boolean comp = false;
        
        for (String line : rawLines) {
            
            if (line.equals("END_OBJECT")) {
                if(complete.equals("true")){comp = true;}
                puzzles.add(new Puzzle(prompt.trim(),answer.trim(),comp));
                inObject = false;
            }else if (inObject) {
                
                if (line.equals("<prompt>")) currentTag = "prompt";
                else if (line.equals("</prompt>")) currentTag = null;
                
                else if (line.equals("<answer>")) currentTag = "answer";
                else if (line.equals("</answer>")) currentTag = null;
                
                else if (line.equals("<complete>")) currentTag = "complete";
                else if (line.equals("</complete>")) currentTag = null;
                
                else if ("prompt".equals(currentTag)) prompt += line + "\n";
                else if ("answer".equals(currentTag)) answer += line + "\n";
                else if ("complete".equals(currentTag)) complete += line + "\n";
                
                
            }else if (line.equals("OBJECT")) {
                inObject = true;
                prompt = answer = "";
                currentTag = null;
            }
        }
        
        return puzzles;
        
    }
    
