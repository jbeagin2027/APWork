class Robot extends Vehicle{
    
    private final String motorType;
    private final String computer;
    private double batteryPercent = 1.0;
    
    public String getMotorType(){return motorType;}
    public String getComputer(){return computer;}
    
    public double getBatteryPercent(){return batteryPercent;}
    public void chargeBattery(){batteryPercent=1.0;}
    public void drainBattery(double percentDrained){batteryPercent-=percentDrained; batteryPercent = Math.max(0.0,batteryPercent);}
    
    public Robot(String inBrand, double inSpeed, int inPassengers, double inCargo, String motor, String comp){
        super(inBrand, inSpeed, inPassengers, inCargo); //uses the super constructor
        motorType = motor; 
        computer = comp;
        batteryPercent = 1.0;
    }
    
    @Override
    public String toString(){
        String result = super.toString() +
                "Motor:\t\t\t" + this.getMotorType()+"\n" +
                "Computer:\t\t" + this.getComputer()+"\n" +
                "Battery Life:\t\t" + this.getBatteryPercent();
        return  result ;
    }
    
}

class Rocket extends Vehicle{
    
    private double range = 0.0;
    private double maxAcceleration = 0.0;
    private String target = "";
    
    public Rocket(String inBrand, double inSpeed, int inPassengers, double inCargo, double inRange, double inAccel, String inTarget){
        super(inBrand, inSpeed, inPassengers, inCargo); //uses the super constructor
        range = inRange; //also include the extra variable in the Vehicle constructor
        maxAcceleration = inAccel;
        target = inTarget;
    }
    
    public double getRange(){return range;}
    public double getMaxAcceleration(){return maxAcceleration;}
    public String getTarget(){return target;} 
    
    public void setRange(double inRange){range=inRange;}
    public void setMaxAcceleration(double inAcceleration){maxAcceleration = inAcceleration;}
    public void setTarget(String inTarget){target = inTarget;}
    
    //usesd the super toString, as well as adding the new variables to it.
    @Override
    public String toString(){
        String result = super.toString() +
                "Range:\t\t\t" + this.getRange()+"\n" +
                "Acceleration: (g)\t" + this.getMaxAcceleration()+"\n" +
                "Current Target:\t\t" + this.getTarget();
        return  result ;
    }
}

class Boat extends Vehicle{
    
