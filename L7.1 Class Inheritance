    }
    
}

class CargoShip extends Boat{
    
    private final int maxContainers;
    private int currentContainers;
    
    public int getMaxContainers(){return maxContainers;}
    public int getCurrentContainers(){return currentContainers;}
    
    public boolean loadShip(int containersToAdd){if(containersToAdd+currentContainers>maxContainers){currentContainers=maxContainers; return false;}else{currentContainers+=containersToAdd; return true;}}
    public boolean unloadShip(int containersToRemove){if(containersToRemove-currentContainers<0){currentContainers=0; return false;}else{currentContainers-=containersToRemove; return true;}}
    
    public CargoShip(String inBrand, double inSpeed, int inPassengers, double inCargo, int crewIn, int maxContainersIn){
        
        super(inBrand, inSpeed, inPassengers, inCargo, crewIn);
        maxContainers = maxContainersIn;
        currentContainers = 0;
        
    }
    
    @Override
    public String toString(){
        return (super.toString()+"\nMax Cont.:\t\t" + this.getMaxContainers()+"\nCurrent Cont.: \t"+this.getCurrentContainers());
    }
    
}

